# ==========================================
# Photo Battle Arena - Environment Variables
# ==========================================

# --- Gemini Scoring Engine ---
# 请替换为你的 Gemini API Key
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- ArtiMuse Scoring Engine (本地多模态美学评估模型) ---
# 设置为 true 启用 ArtiMuse 评分（优先于 Gemini）
# 需要先启动 ArtiMuse API 服务: python /path/to/ArtiMuse/api_server.py
ARTIMUSE_ENABLED=false

# ArtiMuse API 服务地址
ARTIMUSE_URL=http://127.0.0.1:8000

# --- VolcEngine Aesthetic Scoring Engine (火山引擎同款 LAION Aesthetics V2) ---
# 设置为 true 启用 VolcEngine 美学评分（优先级仅次于 ArtiMuse）
# 基于开源 CLIP-ViT-L/14 + LAION MLP 美学模型，输出 0.0-1.0 标准化评分
# 需要先启动美学评分服务: python backend/scripts/volcengine_aesthetic_server.py
VOLCENGINE_ENABLED=true

# VolcEngine 美学评分服务地址
VOLCENGINE_URL=http://127.0.0.1:8001

# --- Server Ports ---
BACKEND_PORT=3001
FRONTEND_PORT=3000
