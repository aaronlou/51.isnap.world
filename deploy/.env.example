# ==========================================
# Photo Battle Arena - 生产环境变量
# 部署时复制到 /opt/photo-battle/.env
# ==========================================

# --- Gemini API Key（最高优先级，有 Key 时优先使用） ---
# 获取: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- HuggingFace 配置（用于 VolcEngine 下载 CLIP 模型）---
# 没有 Token 也能下载，但匿名用户会受限导致极慢
# 获取: https://huggingface.co/settings/tokens
HF_TOKEN=
# 国内用户建议使用镜像（快 10-100 倍）:
# HF_ENDPOINT=https://hf-mirror.com

# --- 选填: ArtiMuse（本地多模态美学评估）---
# ARTIMUSE_ENABLED=true
# ARTIMUSE_URL=http://127.0.0.1:8000

# --- VolcEngine 美学评分（基于 LAION Aesthetics V2，本地 CPU 推理）---
# Gemini 不可用时降级到 VolcEngine，无需 API Key
# 需要先启动评分服务: sudo systemctl start volcengine
VOLCENGINE_ENABLED=true
VOLCENGINE_URL=http://127.0.0.1:8001
