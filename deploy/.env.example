# ==========================================
# Photo Battle Arena - 生产环境变量
# 部署时复制到 /opt/photo-battle/.env
# ==========================================

# --- 必填: Gemini API Key ---
# 获取: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- 选填: ArtiMuse（本地多模态美学评估）---
# ARTIMUSE_ENABLED=true
# ARTIMUSE_URL=http://127.0.0.1:8000

# --- 选填: VolcEngine 美学评分 ---
# VOLCENGINE_ENABLED=true
# VOLCENGINE_URL=http://127.0.0.1:8001
